<div class="bg-brand-light font-sans text-brand-dark min-h-screen">
  
  <!-- HERO BANNER: Futuristic yet warm -->
  <div class="relative w-full h-[60vh] md:h-[70vh] bg-neutral-100 flex items-center justify-center overflow-hidden border-b-4 border-brand-primary">
    <!-- Abstract futuristic cozy background (placeholder) -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-secondary via-brand-light to-neutral-200 opacity-90"></div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto flex flex-col items-center">
      <div class="inline-block bg-brand-primary text-white font-black text-[10px] md:text-sm tracking-widest uppercase px-3 py-1 mb-4 md:mb-6 rounded-sm">
        NUEVA COLECCIÓN
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-4 md:mb-6 text-brand-dark">
        HOGAR.<br/><span class="text-brand-primary">MÁS LINDO.</span>
      </h1>
      <p class="text-base sm:text-lg md:text-2xl font-medium text-neutral-700 mb-8 md:mb-10 max-w-2xl px-2">
        Diseño inteligente, confort colombiano. Todo lo que necesitas para tu espacio, a precios increíbles.
      </p>
      <a href="/collections/all" class="bg-brand-dark text-white font-bold text-base md:text-lg px-8 md:px-10 py-3 md:py-4 uppercase tracking-wide hover:bg-brand-primary transition-colors duration-200 shadow-xl w-full sm:w-auto">
        Ver Todo
      </a>
    </div>
  </div>

  <!-- TICKER / MARQUEE (Agility/Normal vibe) -->
  <div class="bg-brand-accent text-brand-dark py-2 md:py-3 overflow-x-auto whitespace-nowrap border-b-2 border-brand-dark" style="scrollbar-width: none; -ms-overflow-style: none;">
    <div class="font-black text-xs md:text-sm uppercase tracking-widest inline-block px-4">
      <span class="mx-2 md:mx-4">🚚 ENVÍOS A TODA COLOMBIA</span> • 
      <span class="mx-2 md:mx-4">💳 PAGOS SEGUROS CON WOMPI</span> • 
      <span class="mx-2 md:mx-4">🏠 CALIDAD LINDO HOGAR</span> • 
      <span class="mx-2 md:mx-4">🚚 ENVÍOS A TODA COLOMBIA</span> • 
      <span class="mx-2 md:mx-4">💳 PAGOS SEGUROS CON WOMPI</span> • 
      <span class="mx-2 md:mx-4">🏠 CALIDAD LINDO HOGAR</span>
    </div>
  </div>

  <!-- GRID: Uniqlo style rigid grid -->
  <div class="max-w-[1400px] mx-auto px-4 py-10 md:py-16">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end mb-8 md:mb-10 border-b-2 border-brand-dark pb-4">
      <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight mb-2 sm:mb-0">Destacados</h2>
      <a href="#" class="font-bold underline text-brand-primary hover:text-brand-dark text-sm md:text-base">Ver más →</a>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-10">
      
      <!-- Product 1 -->
      <div class="group cursor-pointer border-2 border-transparent hover:border-brand-dark transition-all duration-200 flex flex-col">
        <div class="relative bg-neutral-200 aspect-[4/5] overflow-hidden mb-3 md:mb-4">
          <div class="absolute top-2 left-2 md:top-3 md:left-3 bg-brand-primary text-white text-[10px] md:text-xs font-bold px-2 py-1 uppercase z-10">-10% OFERTA</div>
          <img src="{{ 'sku1-baby-gym.png' | asset_url }}" alt="Gimnasio Bebé" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="px-1 md:px-2 flex-1 flex flex-col">
          <p class="text-[10px] md:text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1">Bebés / Juguetes</p>
          <h3 class="text-lg md:text-xl font-bold leading-tight mb-2 flex-1">Gimnasio de Bebé con Piano</h3>
          <div class="flex items-center justify-between mt-2 md:mt-4">
            <div>
              <p class="text-xs md:text-sm line-through text-neutral-400">$110.000 COP</p>
              <p class="text-xl md:text-2xl font-black text-brand-primary leading-none">$99.000 <span class="text-xs md:text-sm font-bold text-brand-dark">COP</span></p>
            </div>
            <button class="bg-brand-accent hover:bg-brand-primary hover:text-white text-brand-dark w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full font-black text-lg md:text-xl transition-colors duration-200 shadow-sm shrink-0 ml-2">+</button>
          </div>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="group cursor-pointer border-2 border-transparent hover:border-brand-dark transition-all duration-200 flex flex-col">
        <div class="relative bg-neutral-200 aspect-[4/5] overflow-hidden mb-3 md:mb-4">
          <img src="{{ 'sku2-bedding.png' | asset_url }}" alt="Lencería Cama" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="px-1 md:px-2 flex-1 flex flex-col">
          <p class="text-[10px] md:text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1">Hogar / Lencería</p>
          <h3 class="text-lg md:text-xl font-bold leading-tight mb-2 flex-1">Juego de Lencería Premium (Doble)</h3>
          <div class="flex items-center justify-between mt-2 md:mt-4">
            <div>
              <p class="text-xs md:text-sm line-through text-neutral-400">$160.000 COP</p>
              <p class="text-xl md:text-2xl font-black text-brand-primary leading-none">$144.000 <span class="text-xs md:text-sm font-bold text-brand-dark">COP</span></p>
            </div>
            <button class="bg-brand-accent hover:bg-brand-primary hover:text-white text-brand-dark w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full font-black text-lg md:text-xl transition-colors duration-200 shadow-sm shrink-0 ml-2">+</button>
          </div>
        </div>
      </div>

      <!-- Product 3 -->
      <div class="group cursor-pointer border-2 border-transparent hover:border-brand-dark transition-all duration-200 flex flex-col">
        <div class="relative bg-neutral-200 aspect-[4/5] overflow-hidden mb-3 md:mb-4">
          <img src="{{ 'sku3-kitchenware.png' | asset_url }}" alt="Set Cocina" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="px-1 md:px-2 flex-1 flex flex-col">
          <p class="text-[10px] md:text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1">Cocina</p>
          <h3 class="text-lg md:text-xl font-bold leading-tight mb-2 flex-1">Set Utensilios de Cocina (12 piezas)</h3>
          <div class="flex items-center justify-between mt-2 md:mt-4">
            <div>
              <p class="text-xs md:text-sm line-through text-neutral-400">$85.000 COP</p>
              <p class="text-xl md:text-2xl font-black text-brand-primary leading-none">$76.500 <span class="text-xs md:text-sm font-bold text-brand-dark">COP</span></p>
            </div>
            <button class="bg-brand-accent hover:bg-brand-primary hover:text-white text-brand-dark w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full font-black text-lg md:text-xl transition-colors duration-200 shadow-sm shrink-0 ml-2">+</button>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<style>
  /* Hide scrollbar for the ticker */
  ::-webkit-scrollbar {
    display: none;
  }
</style>

{% schema %}
{
  "name": "LHO Grid Homepage",
  "settings": [],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}
